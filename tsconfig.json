{
  "extends": "./tsconfig.base.json",
  "compileOnSave": false,
  "files": ["global.d.ts"],
  "exclude": [
    "node_modules",
    "artifacts",
    "openbot",
    "scripts",
    "lib"
  ],
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["es2022", "dom", "dom.iterable"],
    "paths": {
      "@/*": [
        "./artifacts/openembedded/src/*",
        "./artifacts/mockup-sandbox/src/*"
      ]
    }
  },
  "references": [
    {
      "path": "./lib/db"
    },
    {
      "path": "./lib/api-client-react"
    },
    {
      "path": "./lib/api-zod"
    }
  ]
}
