{
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/openembedded run typecheck && bash scripts/build-vercel.sh",
  "outputDirectory": "artifacts/openembedded/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30,
      "includeFiles": "artifacts/api-server/dist/**"
    }
  }
}
