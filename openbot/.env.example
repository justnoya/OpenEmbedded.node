# ── Discord Bot ──────────────────────────────────────────────────────────────────
# Your bot token (from https://discord.com/developers/applications → Bot → Token)
OPENBOT_TOKEN=your_bot_token_here

# Your Discord application's client ID (from the application's General Information page)
DISCORD_CLIENT_ID=your_client_id_here

# ── API Security ──────────────────────────────────────────────────────────────────
# Secret key the OpenEmbedded api-server uses to authenticate with this bot.
# Generate with: openssl rand -hex 32
OPENBOT_API_KEY=your_secret_api_key_here

# ── Guild Join Callback ───────────────────────────────────────────────────────────
# Optional: when the bot joins a new server, it POSTs an event to this URL.
# Set to your api-server's /api/v1/openbot/guild-event endpoint.
# Example: https://your-app.replit.app/api/v1/openbot/guild-event
OPENBOT_CALLBACK_URL=

# ── Server ───────────────────────────────────────────────────────────────────────
# Port this Express API listens on (default: 3001)
PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────────────
# Origin(s) allowed to call this API. Lock down to your api-server domain in production.
ALLOWED_ORIGIN=*
