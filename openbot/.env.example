# ── Discord Bot ─────────────────────────────────────────────────────────────────
# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Your Discord application / client ID
DISCORD_CLIENT_ID=your_client_id_here

# ── API Server ───────────────────────────────────────────────────────────────────
# Secret key the OpenEmbedded api-server uses to authenticate with this bot.
# Generate with: openssl rand -hex 32
OPENBOT_API_KEY=your_secret_api_key_here

# Port this Express API listens on
PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────────────
# Origin(s) allowed to call this API (your api-server domain).
# Use * only in development — lock down to your real domain in production.
ALLOWED_ORIGIN=*
